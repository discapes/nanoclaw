{
  "name": "nanoclaw",
  "version": "2.7",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "scripts": {
    "start": "node --strip-types src/index.ts",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"container/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"container/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"container/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegramify-markdown": "^1.3.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
